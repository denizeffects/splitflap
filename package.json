{
  "name": "@denizeffects/splitflap",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Split flap text for React. Flap, roll, scramble and odometer modes.",
  "keywords": [
    "react",
    "split-flap",
    "splitflap",
    "text-animation",
    "departure-board",
    "flip",
    "odometer",
    "scramble",
    "typography"
  ],
  "homepage": "https://github.com/denizeffects/splitflap",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denizeffects/splitflap.git"
  },
  "bugs": "https://github.com/denizeffects/splitflap/issues",
  "license": "MIT",
  "author": "deniz (https://x.com/denizeffects)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
